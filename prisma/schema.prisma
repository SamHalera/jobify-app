generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  IN_PROGRESS
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
  GHOSTED
}

enum StageType {
  SCREENING
  TECHNICAL_TEST
  INTERVIEW
  CASE_STUDY
  REFERENCE_CHECK
  OFFER_NEGOTIATION
  OTHER
}

enum StageOutcome {
  PENDING
  PASSED
  FAILED
  CANCELLED
}

enum DocumentType {
  CV
  COVER_LETTER
  OTHER
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique
  website      String?
  logoUrl      String?
  notes        String?
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id          String            @id @default(cuid())
  jobTitle    String
  jobUrl      String?
  location    String?
  salary      String?
  isRemote    Boolean           @default(false)
  status      ApplicationStatus @default(WISHLIST)
  appliedAt   DateTime?
  notes       String?
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  stages      RecruitmentStage[]
  documents   ApplicationDocument[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([companyId])
}

model RecruitmentStage {
  id            String       @id @default(cuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          StageType
  title         String
  scheduledAt   DateTime?
  completedAt   DateTime?
  outcome       StageOutcome @default(PENDING)
  notes         String?
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([applicationId])
}

model Document {
  id           String               @id @default(cuid())
  name         String
  type         DocumentType
  fileName     String
  storagePath  String
  mimeType     String               @default("application/pdf")
  sizeBytes    Int
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  applications ApplicationDocument[]
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  attachedAt    DateTime    @default(now())

  @@unique([applicationId, documentId])
}
